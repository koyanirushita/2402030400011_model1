<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport"
content="width=device-width, initial-scale=1.0">

<title>Bill - Smart Canteen</title>

<!-- FONT AWESOME -->
<link rel="stylesheet"
href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css"/>

<style>

*{
    margin:0;
    padding:0;
    box-sizing:border-box;
    font-family:Arial,sans-serif;
}

body{
    background:#f4f4f4;
}

/* HEADER */

header{
    width:100%;
    background:#111827;
    display:flex;
    justify-content:space-between;
    align-items:center;
    padding:18px 8%;
    position:sticky;
    top:0;
    z-index:1000;
}

.logo{
    color:white;
    font-size:30px;
    font-weight:bold;
}

.logo i{
    color:#f59e0b;
}

nav{
    display:flex;
    flex-wrap:wrap;
    justify-content:center;
}

nav a{
    color:white;
    text-decoration:none;
    margin-left:25px;
    font-size:18px;
    transition:0.3s;
}

nav a:hover{
    color:#f59e0b;
}

/* HERO */

.hero{
    height:40vh;
    background:linear-gradient(to right,#111827,#1f2937);
    display:flex;
    justify-content:center;
    align-items:center;
    text-align:center;
    color:white;
    padding:20px;
}

.hero h1{
    font-size:60px;
    margin-bottom:15px;
}

.hero p{
    font-size:22px;
}

/* BILL SECTION */

.bill-section{
    padding:80px 8%;
}

.bill-container{
    max-width:1000px;
    margin:auto;
    background:white;
    border-radius:25px;
    overflow:hidden;
    box-shadow:0 8px 25px rgba(0,0,0,0.1);
}

/* BILL HEADER */

.bill-header{
    background:#111827;
    color:white;
    padding:40px;
    text-align:center;
}

.bill-header h2{
    font-size:42px;
    margin-bottom:10px;
}

.bill-header p{
    font-size:18px;
    color:#d1d5db;
}

/* BILL BODY */

.bill-body{
    padding:40px;
}

/* TABLE */

table{
    width:100%;
    border-collapse:collapse;
}

table thead{
    background:#f59e0b;
    color:white;
}

table th{
    padding:18px;
    font-size:20px;
}

table td{
    padding:18px;
    text-align:center;
    border-bottom:1px solid #ddd;
    font-size:18px;
}

.food-img{
    width:80px;
    height:60px;
    object-fit:cover;
    border-radius:10px;
}

/* SUMMARY */

.bill-summary{
    margin-top:40px;
    background:#f9fafb;
    padding:30px;
    border-radius:20px;
}

.summary-row{
    display:flex;
    justify-content:space-between;
    margin-bottom:18px;
    font-size:22px;
    color:#111827;
}

.summary-row.total{
    font-size:30px;
    font-weight:bold;
    color:#f59e0b;
    border-top:2px solid #ddd;
    padding-top:20px;
}

/* BUTTON */

.bill-btns{
    margin-top:35px;
    text-align:center;
}

.bill-btns button{
    padding:15px 40px;
    margin:10px;
    border:none;
    border-radius:10px;
    font-size:18px;
    cursor:pointer;
    transition:0.3s;
}

.print-btn{
    background:#111827;
    color:white;
}

.print-btn:hover{
    background:#f59e0b;
}

.pay-btn{
    background:#22c55e;
    color:white;
}

.pay-btn:hover{
    background:#16a34a;
}

/* EMPTY BILL */

.empty-bill{
    text-align:center;
    padding:80px 20px;
}

.empty-bill i{
    font-size:80px;
    color:#f59e0b;
    margin-bottom:20px;
}

.empty-bill h2{
    font-size:40px;
    color:#111827;
    margin-bottom:15px;
}

.empty-bill p{
    color:#666;
    font-size:20px;
}

/* FOOTER */

footer{
    background:#111827;
    color:white;
    text-align:center;
    padding:40px 8%;
    margin-top:80px;
}

footer h2{
    font-size:32px;
    margin-bottom:15px;
}

footer p{
    margin-bottom:15px;
}

.social-icons{
    margin-top:15px;
}

.social-icons i{
    font-size:28px;
    margin:0 12px;
    cursor:pointer;
    transition:0.3s;
}

.social-icons i:hover{
    color:#f59e0b;
}

/* RESPONSIVE */

@media(max-width:768px){

    header{
        flex-direction:column;
        gap:15px;
    }

    nav a{
        margin:8px 10px;
        font-size:16px;
    }

    .hero h1{
        font-size:42px;
    }

    .hero p{
        font-size:18px;
    }

    .bill-body{
        overflow-x:auto;
    }

    table{
        min-width:700px;
    }

    .summary-row{
        font-size:18px;
    }

    .summary-row.total{
        font-size:24px;
    }
}

</style>
</head>
<body>

<!-- HEADER -->

<header>

    <div class="logo">
        <i class="fa-solid fa-file-invoice"></i>
        Smart Canteen
    </div>

    <nav>
        <a href="../website/home.html">Home</a>
        <a href="../website/menu.html">Menu</a>
        <a href="../website/service.html">Services</a>
        <a href="../website/aboutus.html">About</a>
        <a href="../website/contactus.html">Contact</a>
        <a href="../website/billing.html">Bill</a>
        <a href="../website/payment.html">Payment</a>
        <a href="../website/cart.html">Cart</a>
        <a href="../website/login.html">Log in</a>
    </nav>

</header>

<!-- HERO -->

<section class="hero">

    <div>

        <h1>Your Food Bill</h1>

        <p>
            Smart Canteen Billing System with GST
        </p>

    </div>

</section>

<!-- BILL SECTION -->

<section class="bill-section">

    <div class="bill-container">

        <div class="bill-header">

            <h2>Smart Canteen Invoice</h2>

            <p id="bill-date"></p>

        </div>

        <div class="bill-body">

            <div id="bill-content">

            </div>

        </div>

    </div>

</section>

<!-- FOOTER -->

<footer>

    <h2>Smart Canteen Company</h2>

    <p>
        Smart Food Ordering Platform for Students & Companies.
    </p>

    <div class="social-icons">

        <i class="fa-brands fa-facebook"></i>
        <i class="fa-brands fa-instagram"></i>
        <i class="fa-brands fa-twitter"></i>
        <i class="fa-brands fa-linkedin"></i>

    </div>

    <p style="margin-top:20px;">
        © 2026 Smart Canteen. All Rights Reserved.
    </p>

</footer>

<!-- JAVASCRIPT -->

<script>

/* DATE */

let today = new Date();

document.getElementById("bill-date").innerHTML =
today.toDateString();

/* GET CART */

let cart = JSON.parse(localStorage.getItem("cart")) || [];

const billContent = document.getElementById("bill-content");

/* IF CART EMPTY */

if(cart.length === 0){

    billContent.innerHTML = `

    <div class="empty-bill">

        <i class="fa-solid fa-cart-shopping"></i>

        <h2>No Items Found</h2>

        <p>Your cart is empty. Please add food items.</p>

    </div>

    `;

}else{

    let subtotal = 0;

    let tableRows = "";

    cart.forEach(item => {

        let itemTotal = item.price * item.quantity;

        subtotal += itemTotal;

        tableRows += `

        <tr>

            <td>
                <img src="${item.image}"
                class="food-img">
            </td>

            <td>${item.name}</td>

            <td>₹${item.price}</td>

            <td>${item.quantity}</td>

            <td>₹${itemTotal}</td>

        </tr>

        `;
    });

    /* GST */

    let gst = subtotal * 0.18;

    let finalTotal = subtotal + gst;

    billContent.innerHTML = `

    <table>

        <thead>

            <tr>

                <th>Image</th>
                <th>Food Item</th>
                <th>Price</th>
                <th>Qty</th>
                <th>Total</th>

            </tr>

        </thead>

        <tbody>

            ${tableRows}

        </tbody>

    </table>

    <!-- SUMMARY -->

    <div class="bill-summary">

        <div class="summary-row">

            <span>Subtotal</span>

            <span>₹${subtotal.toFixed(2)}</span>

        </div>

        <div class="summary-row">

            <span>GST (18%)</span>

            <span>₹${gst.toFixed(2)}</span>

        </div>

        <div class="summary-row total">

            <span>Grand Total</span>

            <span>₹${finalTotal.toFixed(2)}</span>

        </div>

    </div>

    <!-- BUTTONS -->

    <div class="bill-btns">

        <button class="print-btn"
        onclick="window.print()">

            <i class="fa-solid fa-print"></i>
            Print Bill

        </button>

        <button class="pay-btn"
        onclick="goPayment()">

            <i class="fa-solid fa-credit-card"></i>
            Proceed To Payment

        </button>

    </div>

    `;
}

/* PAYMENT */

function goPayment(){

    window.location.href =
    "../website/payment.html";
}

</script>

</body>
</html>
