<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <title>Menu - Smart Canteen</title>

    <!-- FONT AWESOME -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css"/>

    <style>
        *{
            margin:0;
            padding:0;
            box-sizing:border-box;
            font-family:Arial, sans-serif;
        }

        body{
            background:#f4f4f4;
        }

        /* HEADER */
        header{
            width:100%;
            background:#111827;
            display:flex;
            justify-content:space-between;
            align-items:center;
            padding:18px 8%;
            position:sticky;
            top:0;
            z-index:1000;
        }

        .logo{
            color:white;
            font-size:30px;
            font-weight:bold;
        }

        .logo i{
            color:#f59e0b;
        }

        /* SEARCH BAR STYLE */
        .search-container {
            position: relative;
            display: flex;
            align-items: center;
            background: #1f2937;
            border-radius: 8px;
            padding: 5px 15px;
            border: 1px solid #374151;
            margin-left: 20px;
        }

        .search-container input {
            background: transparent;
            border: none;
            outline: none;
            color: white;
            font-size: 16px;
            padding: 5px;
            width: 200px;
            transition: width 0.3s ease;
        }

        .search-container input::placeholder {
            color: #9ca3af;
        }

        .search-container i {
            color: #f59e0b;
            font-size: 18px;
        }

        nav{
            display:flex;
            flex-wrap:wrap;
            justify-content:center;
            align-items: center;
        }

        nav a{
            color:white;
            text-decoration:none;
            margin-left:25px;
            font-size:18px;
            transition:0.3s;
        }

        nav a:hover{
            color:#f59e0b;
        }

        /* HERO SECTION */
        .hero{
            height:45vh;
            background:linear-gradient(to right,#111827,#1f2937);
            display:flex;
            justify-content:center;
            align-items:center;
            text-align:center;
            color:white;
            padding:20px;
        }

        .hero h1{
            font-size:60px;
            margin-bottom:20px;
        }

        .hero p{
            font-size:22px;
        }

        /* MENU SECTION */
        .menu-section{
            padding:80px 8%;
            text-align:center;
        }

        .menu-section h2{
            font-size:45px;
            color:#111827;
            margin-bottom:50px;
        }

        .menu-container{
            display:grid;
            grid-template-columns:repeat(auto-fit,minmax(260px,1fr));
            gap:30px;
        }

        .menu-card{
            background:white;
            border-radius:20px;
            overflow:hidden;
            box-shadow:0 5px 15px rgba(0,0,0,0.1);
            transition:0.3s;
        }

        .menu-card:hover{
            transform:translateY(-10px);
        }

        .menu-card img{
            width:100%;
            height:220px;
            object-fit:cover;
        }

        .menu-card h3{
            margin-top:20px;
            font-size:28px;
            color:#111827;
        }

        .menu-card p{
            color:#666;
            padding:10px 20px;
            line-height:1.6;
        }

        .price{
            display:block;
            font-size:26px;
            color:#f59e0b;
            font-weight:bold;
            margin-bottom:15px;
        }

        .menu-card button{
            margin-bottom:25px;
            padding:12px 28px;
            border:none;
            background:#111827;
            color:white;
            border-radius:8px;
            font-size:16px;
            cursor:pointer;
            transition:0.3s;
        }

        .menu-card button:hover{
            background:#f59e0b;
        }

        /* NO RESULTS MESSAGE */
        #no-results-msg {
            display: none;
            font-size: 22px;
            color: #666;
            margin-top: 30px;
            grid-column: 1 / -1;
        }

        /* POPUP */
        .popup{
            width:100%;
            height:100vh;
            background:rgba(0,0,0,0.6);
            position:fixed;
            top:0;
            left:0;
            display:flex;
            justify-content:center;
            align-items:center;
            visibility:hidden;
            opacity:0;
            transition:0.3s;
            z-index:2000;
        }

        .popup.active{
            visibility:visible;
            opacity:1;
        }

        .popup-box{
            width:350px;
            background:white;
            padding:40px 30px;
            border-radius:20px;
            text-align:center;
            animation:popupAnimation 0.5s ease;
        }

        @keyframes popupAnimation{
            from{
                transform:scale(0.5);
                opacity:0;
            }
            to{
                transform:scale(1);
                opacity:1;
            }
        }

        .popup-box i{
            font-size:70px;
            color:#22c55e;
            margin-bottom:20px;
        }

        .popup-box h2{
            font-size:32px;
            color:#111827;
            margin-bottom:15px;
        }

        .popup-box p{
            color:#666;
            font-size:18px;
            margin-bottom:25px;
        }

        .popup-box button{
            padding:12px 35px;
            border:none;
            background:#f59e0b;
            color:white;
            font-size:18px;
            border-radius:8px;
            cursor:pointer;
            transition:0.3s;
        }

        .popup-box button:hover{
            background:#ff8800;
        }

        /* FOOTER */
        footer{
            background:#111827;
            color:white;
            text-align:center;
            padding:40px 8%;
        }

        .footer-links{
            margin-bottom:25px;
        }

        .footer-links a{
            color:white;
            text-decoration:none;
            margin:0 15px;
            font-size:18px;
            transition:0.3s;
        }

        .footer-links a:hover{
            color:#f59e0b;
        }

        footer h2{
            font-size:32px;
            margin-bottom:15px;
        }

        footer p{
            margin-bottom:15px;
        }

        .social-icons{
            margin-top:15px;
        }

        .social-icons i{
            font-size:28px;
            margin:0 12px;
            cursor:pointer;
            transition:0.3s;
        }

        .social-icons i:hover{
            color:#f59e0b;
        }

        /* RESPONSIVE */
        @media(max-width:768px){
            header{
                flex-direction:column;
                gap:15px;
            }

            .search-container {
                margin-left: 0;
                width: 90%;
            }
            
            .search-container input {
                width: 100%;
            }

            nav a{
                margin:0 10px;
                font-size:16px;
            }

            .hero h1{
                font-size:42px;
            }

            .hero p{
                font-size:18px;
            }

            .footer-links a{
                display:inline-block;
                margin:8px 10px;
            }
        }
    </style>
</head>
<body>

