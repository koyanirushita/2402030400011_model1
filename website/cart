<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">

<title>Cart - Smart Canteen</title>

<!-- FONT AWESOME -->
<link rel="stylesheet"
href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css"/>

<style>

*{
    margin:0;
    padding:0;
    box-sizing:border-box;
    font-family:Arial,sans-serif;
}

body{
    background:#f4f4f4;
}

/* HEADER */

header{
    width:100%;
    background:#111827;
    display:flex;
    justify-content:space-between;
    align-items:center;
    padding:18px 8%;
    position:sticky;
    top:0;
    z-index:1000;
}

.logo{
    color:white;
    font-size:30px;
    font-weight:bold;
}

.logo i{
    color:#f59e0b;
}

nav{
    display:flex;
    flex-wrap:wrap;
    justify-content:center;
}

nav a{
    color:white;
    text-decoration:none;
    margin-left:25px;
    font-size:18px;
    transition:0.3s;
}

nav a:hover{
    color:#f59e0b;
}

/* HERO */

.hero{
    height:40vh;
    background:linear-gradient(to right,#111827,#1f2937);
    display:flex;
    justify-content:center;
    align-items:center;
    text-align:center;
    color:white;
    padding:20px;
}

.hero h1{
    font-size:60px;
    margin-bottom:20px;
}

.hero p{
    font-size:22px;
}

/* CART SECTION */

.cart-section{
    padding:80px 8%;
}

.cart-section h2{
    text-align:center;
    font-size:45px;
    color:#111827;
    margin-bottom:50px;
}

.cart-container{
    display:flex;
    flex-direction:column;
    gap:25px;
}

/* CART ITEM */

.cart-item{
    background:white;
    border-radius:20px;
    padding:20px;
    display:flex;
    justify-content:space-between;
    align-items:center;
    flex-wrap:wrap;
    gap:20px;
    box-shadow:0 5px 15px rgba(0,0,0,0.1);
}

.cart-left{
    display:flex;
    align-items:center;
    gap:20px;
}

.cart-left img{
    width:130px;
    height:100px;
    object-fit:cover;
    border-radius:12px;
}

.cart-details h3{
    font-size:28px;
    color:#111827;
    margin-bottom:10px;
}

.cart-details p{
    color:#666;
    font-size:18px;
}

.cart-right{
    display:flex;
    align-items:center;
    gap:20px;
    flex-wrap:wrap;
}

/* QUANTITY */

.quantity-box{
    display:flex;
    align-items:center;
    border-radius:10px;
    overflow:hidden;
    background:#f3f4f6;
}

.quantity-box button{
    width:42px;
    height:42px;
    border:none;
    background:#111827;
    color:white;
    font-size:22px;
    cursor:pointer;
    transition:0.3s;
}

.quantity-box button:hover{
    background:#f59e0b;
}

.quantity{
    width:50px;
    text-align:center;
    font-size:20px;
    font-weight:bold;
}

/* PRICE */

.item-total{
    font-size:25px;
    color:#f59e0b;
    font-weight:bold;
}

/* REMOVE BUTTON */

.remove-btn{
    padding:10px 20px;
    border:none;
    background:#dc2626;
    color:white;
    border-radius:8px;
    cursor:pointer;
    font-size:16px;
    transition:0.3s;
}

.remove-btn:hover{
    background:#b91c1c;
}

/* TOTAL BOX */

.total-box{
    margin-top:50px;
    background:white;
    border-radius:20px;
    padding:35px;
    text-align:center;
    box-shadow:0 5px 15px rgba(0,0,0,0.1);
}

.total-box h3{
    font-size:38px;
    color:#111827;
    margin-bottom:20px;
}

.total-price{
    font-size:42px;
    color:#f59e0b;
    font-weight:bold;
}

.checkout-btn{
    margin-top:25px;
    padding:15px 40px;
    border:none;
    background:#111827;
    color:white;
    border-radius:10px;
    font-size:18px;
    cursor:pointer;
    transition:0.3s;
}

.checkout-btn:hover{
    background:#f59e0b;
}

/* EMPTY CART */

.empty-cart{
    text-align:center;
    padding:60px;
    background:white;
    border-radius:20px;
    box-shadow:0 5px 15px rgba(0,0,0,0.1);
}

.empty-cart i{
    font-size:70px;
    color:#f59e0b;
    margin-bottom:20px;
}

.empty-cart h3{
    font-size:35px;
    color:#111827;
    margin-bottom:10px;
}

.empty-cart p{
    color:#666;
    font-size:20px;
}

/* FOOTER */

footer{
    background:#111827;
    color:white;
    text-align:center;
    padding:40px 8%;
    margin-top:80px;
}

footer h2{
    font-size:32px;
    margin-bottom:15px;
}

footer p{
    margin-bottom:15px;
}

.social-icons{
    margin-top:15px;
}

.social-icons i{
    font-size:28px;
    margin:0 12px;
    cursor:pointer;
    transition:0.3s;
}

.social-icons i:hover{
    color:#f59e0b;
}

/* RESPONSIVE */

@media(max-width:768px){

    header{
        flex-direction:column;
        gap:15px;
    }

    nav a{
        margin:8px 10px;
        font-size:16px;
    }

    .hero h1{
        font-size:42px;
    }

    .hero p{
        font-size:18px;
    }

    .cart-item{
        flex-direction:column;
        text-align:center;
    }

    .cart-left{
        flex-direction:column;
    }

    .cart-right{
        justify-content:center;
    }
}

</style>
</head>
<body>

<!-- HEADER -->

<header>

    <div class="logo">
        <i class="fa-solid fa-cart-shopping"></i>
        Smart Canteen
    </div>

    <nav>
        <a href="../website/home.html">Home</a>
        <a href="../website/menu.html">Menu</a>
        <a href="../website/service.html">Services</a>
        <a href="../website/aboutus.html">About</a>
        <a href="../website/contactus.html">Contact</a>
        <a href="../website/billing.html">Bill</a>
        <a href="../website/payment.html">Payment</a>
        <a href="../website/cart.html">Cart</a>
        <a href="../website/login.html">Log in</a>
    </nav>

</header>

<!-- HERO -->

<section class="hero">

    <div>

        <h1>Your Cart</h1>

        <p>
            Manage your food items easily.
        </p>

    </div>

</section>

<!-- CART SECTION -->

<section class="cart-section">

    <h2>Cart Items</h2>

    <div class="cart-container" id="cart-container">

    </div>

    <!-- TOTAL -->

    <div class="total-box">

        <h3>Total Amount</h3>

        <div class="total-price" id="grand-total">
            ₹0
        </div>

        <button class="checkout-btn">
            Proceed to Payment
        </button>

    </div>

</section>

<!-- FOOTER -->

<footer>

    <h2>Smart Canteen Company</h2>

    <p>
        Smart Food Ordering Platform for Students & Companies.
    </p>

    <div class="social-icons">

        <i class="fa-brands fa-facebook"></i>
        <i class="fa-brands fa-instagram"></i>
        <i class="fa-brands fa-twitter"></i>
        <i class="fa-brands fa-linkedin"></i>

    </div>

    <p style="margin-top:20px;">
        © 2026 Smart Canteen. All Rights Reserved.
    </p>

</footer>

<!-- JAVASCRIPT -->

<script>

let cart = JSON.parse(localStorage.getItem("cart")) || [];

const cartContainer = document.getElementById("cart-container");
const grandTotal = document.getElementById("grand-total");

/* DISPLAY CART */

function displayCart(){

    cartContainer.innerHTML = "";

    if(cart.length === 0){

        cartContainer.innerHTML = `

        <div class="empty-cart">

            <i class="fa-solid fa-cart-shopping"></i>

            <h3>Your Cart is Empty</h3>

            <p>Add delicious food items from menu.</p>

        </div>

        `;

        grandTotal.innerHTML = "₹0";

        return;
    }

    let total = 0;

    cart.forEach((item,index)=>{

        let itemTotal = item.price * item.quantity;

        total += itemTotal;

        cartContainer.innerHTML += `

        <div class="cart-item">

            <div class="cart-left">

                <img src="${item.image}" alt="">

                <div class="cart-details">

                    <h3>${item.name}</h3>

                    <p>Price : ₹${item.price}</p>

                </div>

            </div>

            <div class="cart-right">

                <div class="quantity-box">

                    <button onclick="decreaseQuantity(${index})">
                        -
                    </button>

                    <div class="quantity">
                        ${item.quantity}
                    </div>

                    <button onclick="increaseQuantity(${index})">
                        +
                    </button>

                </div>

                <div class="item-total">
                    ₹${itemTotal}
                </div>

                <button class="remove-btn"
                onclick="removeItem(${index})">

                    Remove

                </button>

            </div>

        </div>

        `;
    });

    grandTotal.innerHTML = `₹${total}`;

    localStorage.setItem("cart", JSON.stringify(cart));
}

/* PLUS */

function increaseQuantity(index){

    cart[index].quantity++;

    displayCart();
}

/* MINUS */

function decreaseQuantity(index){

    if(cart[index].quantity > 1){

        cart[index].quantity--;

    }else{

        cart.splice(index,1);
    }

    displayCart();
}

/* REMOVE */

function removeItem(index){

    cart.splice(index,1);

    displayCart();
}

/* LOAD */

displayCart();

</script>

</body>
</html>
