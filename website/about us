<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <title>About Us - Smart Canteen</title>

    <!-- FONT AWESOME -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css"/>

    <style>

        *{
            margin:0;
            padding:0;
            box-sizing:border-box;
            font-family:Arial, sans-serif;
        }

        body{
            background:#f4f4f4;
        }

        /* HEADER */

        header{
            width:100%;
            background:#111827;
            display:flex;
            justify-content:space-between;
            align-items:center;
            padding:18px 8%;
            position:sticky;
            top:0;
            z-index:1000;
            flex-wrap:wrap;
        }

        .logo{
            color:white;
            font-size:30px;
            font-weight:bold;
        }

        .logo i{
            color:#f59e0b;
        }

        nav{
            display:flex;
            align-items:center;
            flex-wrap:wrap;
            justify-content:center;
        }

        nav a{
            color:white;
            text-decoration:none;
            margin-left:25px;
            font-size:18px;
            transition:0.3s;
        }

        nav a:hover{
            color:#f59e0b;
        }

        /* SEARCH CONTAINER - SAME STYLE AS OTHER PAGES */
        .search-container {
            position: relative;
            display: flex;
            align-items: center;
            background: #1f2937;
            border-radius: 8px;
            padding: 5px 15px;
            border: 1px solid #374151;
            margin-left: 20px;
        }

        .search-container input {
            background: transparent;
            border: none;
            outline: none;
            color: white;
            font-size: 16px;
            padding: 5px;
            width: 200px;
            transition: width 0.3s ease;
        }

        .search-container input::placeholder {
            color: #9ca3af;
        }

        .search-container i {
            color: #f59e0b;
            font-size: 18px;
            cursor: pointer;
        }

        /* HERO SECTION */

        .hero{
            height:50vh;
            background:linear-gradient(to right,#111827,#1f2937);
            display:flex;
            justify-content:center;
            align-items:center;
            text-align:center;
            color:white;
            padding:20px;
        }

        .hero h1{
            font-size:60px;
            margin-bottom:20px;
        }

        .hero p{
            font-size:22px;
            max-width:700px;
            line-height:1.8;
        }

        /* ABOUT SECTION */

        .about-section{
            padding:80px 8%;
            display:flex;
            justify-content:center;
            align-items:center;
            gap:50px;
            flex-wrap:wrap;
        }

        .about-image{
            flex:1;
            min-width:300px;
        }

        .about-image img{
            width:100%;
            border-radius:20px;
            box-shadow:0 5px 20px rgba(0,0,0,0.2);
        }

        .about-content{
            flex:1;
            min-width:300px;
        }

        .about-content h2{
            font-size:45px;
            color:#111827;
            margin-bottom:20px;
        }

        .about-content p{
            font-size:18px;
            color:#666;
            line-height:1.9;
            margin-bottom:20px;
        }

        .about-content button{
            padding:14px 35px;
            border:none;
            background:#f59e0b;
            color:white;
            font-size:18px;
            border-radius:8px;
            cursor:pointer;
            transition:0.3s;
        }

        .about-content button:hover{
            background:#ff8800;
        }

        /* FEATURES */

        .features{
            padding:80px 8%;
            text-align:center;
            background:white;
        }

        .features h2{
            font-size:45px;
            color:#111827;
            margin-bottom:50px;
        }

        .feature-container{
            display:grid;
            grid-template-columns:repeat(auto-fit,minmax(250px,1fr));
            gap:30px;
        }

        .feature-box{
            background:#f4f4f4;
            padding:40px 25px;
            border-radius:20px;
            transition:0.3s;
            box-shadow:0 5px 15px rgba(0,0,0,0.1);
        }

        .feature-box:hover{
            transform:translateY(-10px);
        }

        .feature-box i{
            font-size:55px;
            color:#f59e0b;
            margin-bottom:20px;
        }

        .feature-box h3{
            font-size:28px;
            margin-bottom:15px;
            color:#111827;
        }

        .feature-box p{
            color:#666;
            line-height:1.7;
        }

        /* TEAM SECTION */

        .team{
            padding:80px 8%;
            text-align:center;
        }

        .team h2{
            font-size:45px;
            color:#111827;
            margin-bottom:50px;
        }

        .team-container{
            display:grid;
            grid-template-columns:repeat(auto-fit,minmax(250px,1fr));
            gap:30px;
        }

        .team-box{
            background:white;
            border-radius:20px;
            overflow:hidden;
            box-shadow:0 5px 15px rgba(0,0,0,0.1);
            transition:0.3s;
        }

        .team-box:hover{
            transform:translateY(-10px);
        }

        .team-box img{
            width:100%;
            height:280px;
            object-fit:cover;
        }

        .team-box h3{
            margin-top:20px;
            font-size:28px;
            color:#111827;
        }

        .team-box p{
            color:#f59e0b;
            margin:15px 0 25px;
            font-size:18px;
        }

        /* POPUP */

        .popup{
            width:100%;
            height:100vh;
            background:rgba(0,0,0,0.6);
            position:fixed;
            top:0;
            left:0;
            display:flex;
            justify-content:center;
            align-items:center;
            visibility:hidden;
            opacity:0;
            transition:0.3s;
            z-index:2000;
        }

        .popup.active{
            visibility:visible;
            opacity:1;
        }

        .popup-box{
            width:350px;
            background:white;
            padding:40px 30px;
            border-radius:20px;
            text-align:center;
            animation:popupAnimation 0.5s ease;
        }

        @keyframes popupAnimation{
            from{
                transform:scale(0.5);
                opacity:0;
            }
            to{
                transform:scale(1);
                opacity:1;
            }
        }

        .popup-box i{
            font-size:70px;
            color:#22c55e;
            margin-bottom:20px;
        }

        .popup-box h2{
            font-size:32px;
            color:#111827;
            margin-bottom:15px;
        }

        .popup-box p{
            color:#666;
            font-size:18px;
            margin-bottom:25px;
        }

        .popup-box button{
            padding:12px 35px;
            border:none;
            background:#f59e0b;
            color:white;
            font-size:18px;
            border-radius:8px;
            cursor:pointer;
            transition:0.3s;
        }

        .popup-box button:hover{
            background:#ff8800;
        }

        /* FOOTER */

        footer{
            background:#111827;
            color:white;
            text-align:center;
            padding:40px 8%;
        }

        .footer-links{
            margin-bottom:25px;
        }

        .footer-links a{
            color:white;
            text-decoration:none;
            margin:0 15px;
            font-size:18px;
            transition:0.3s;
        }

        .footer-links a:hover{
            color:#f59e0b;
        }

        footer h2{
            font-size:32px;
            margin-bottom:15px;
        }

        footer p{
            margin-bottom:15px;
        }

        .social-icons{
            margin-top:15px;
        }

        .social-icons i{
            font-size:28px;
            margin:0 12px;
            cursor:pointer;
            transition:0.3s;
        }

        .social-icons i:hover{
            color:#f59e0b;
        }

        /* RESPONSIVE */

        @media(max-width:768px){

            header{
                flex-direction:column;
                gap:15px;
            }

            .search-container {
                margin-left: 0;
                width: 90%;
            }
            
            .search-container input {
                width: 100%;
            }

            nav{
                justify-content:center;
            }

            nav a{
                margin:10px;
                font-size:16px;
            }

            .hero h1{
                font-size:42px;
            }

            .hero p{
                font-size:18px;
            }
        }

    </style>
</head>
<body>

    <!-- HEADER -->

    <header>

        <div class="logo">
            <i class="fa-solid fa-burger"></i>
            Smart Canteen
        </div>

        <nav>

            <a href="../website/home.html">Home</a>
            <a href="../website/menu.html">Menu</a>
            <a href="../website/cart.html">Cart</a>
            <a href="../website/login.html">Log in</a>
            
            <!-- SEARCH CONTAINER WITH REDIRECT LOGIC -->
            <div class="search-container">
                <input type="text" id="search-input" placeholder="Search menu..." onkeydown="redirectToMenu(event)">
                <i class="fa-solid fa-magnifying-glass" onclick="searchIconClick()"></i>
            </div>

        </nav>

    </header>

    <!-- HERO SECTION -->

    <section class="hero">

        <div>
            <h1>About Smart Canteen</h1>
            <p>
                Smart Canteen is a modern food ordering platform
                designed to provide fast, hygienic, and delicious
                meals for students and employees.
            </p>
        </div>

    </section>

    <!-- ABOUT SECTION -->

    <section class="about-section">

        <div class="about-image">
            <img src="https://images.unsplash.com/photo-1552566626-52f8b828add9?q=80&w=1200&auto=format&fit=crop">
        </div>

        <div class="about-content">

            <h2>Who We Are</h2>

            <p>
                Smart Canteen helps students order food quickly
                without standing in long queues. Our mission is
                to provide quality food with smart digital service.
            </p>

            <p>
                We focus on fast delivery, clean food preparation,
                online payment systems, and excellent customer service.
            </p>

            <button onclick="showPopup()">
                Learn More
            </button>

        </div>

    </section>

    <!-- FEATURES -->

    <section class="features">

        <h2>Why Choose Us?</h2>

        <div class="feature-container">

            <div class="feature-box">
                <i class="fa-solid fa-truck-fast"></i>
                <h3>Fast Delivery</h3>
                <p>Quick food delivery inside campus.</p>
            </div>

            <div class="feature-box">
                <i class="fa-solid fa-utensils"></i>
                <h3>Fresh Food</h3>
                <p>Delicious and hygienic meals every day.</p>
            </div>

            <div class="feature-box">
                <i class="fa-solid fa-mobile-screen"></i>
                <h3>Smart Ordering</h3>
                <p>Easy online ordering with modern UI.</p>
            </div>

        </div>

    </section>

    <!-- TEAM SECTION -->

    <section class="team">

        <h2>Our Team</h2>

        <div class="team-container">

            <div class="team-box">
                <img src="https://images.unsplash.com/photo-1500648767791-00dcc994a43e?q=80&w=1200&auto=format&fit=crop">
                <h3>Rahul Sharma</h3>
                <p>Founder & CEO</p>
            </div>

            <div class="team-box">
                <img src="https://images.unsplash.com/photo-1494790108377-be9c29b29330?q=80&w=1200&auto=format&fit=crop">
                <h3>Priya Patel</h3>
                <p>Manager</p>
            </div>

            <div class="team-box">
                <img src="https://images.unsplash.com/photo-1506794778202-cad84cf45f1d?q=80&w=1200&auto=format&fit=crop">
                <h3>Aman Verma</h3>
                <p>Delivery Head</p>
            </div>

        </div>

    </section>

    <!-- POPUP -->

    <div class="popup" id="popup">

        <div class="popup-box">
            <i class="fa-solid fa-circle-check"></i>
            <h2>Welcome!</h2>
            <p>
                Thank you for visiting Smart Canteen.
                We are happy to serve you.
            </p>
            <button onclick="closePopup()">OK</button>
        </div>

    </div>

    <!-- FOOTER -->

    <footer>

        <div class="footer-links">
            <a href="../website/service.html">Services</a>
            <a href="../website/aboutus.html">About</a>
            <a href="../website/contactus.html">Contact</a>
        </div>

        <h2>Smart Canteen Company</h2>

        <p>Smart Food Ordering Platform for Students & Companies.</p>

        <div class="social-icons">
            <i class="fa-brands fa-facebook"></i>
            <i class="fa-brands fa-instagram"></i>
            <i class="fa-brands fa-twitter"></i>
            <i class="fa-brands fa-linkedin"></i>
        </div>

        <p style="margin-top:20px;">© 2026 Smart Canteen. All Rights Reserved.</p>

    </footer>

    <!-- JAVASCRIPT -->

    <script>

        /* SEARCH REDIRECT LOGIC */
        function redirectToMenu(event) {
            if (event.key === "Enter") {
                let value = document.getElementById('search-input').value.trim();
                if(value !== "") {
                    window.location.href = "../website/menu.html?search=" + encodeURIComponent(value);
                }
            }
        }

        function searchIconClick() {
            let value = document.getElementById('search-input').value.trim();
            if(value !== "") {
                window.location.href = "../website/menu.html?search=" + encodeURIComponent(value);
            }
        }

        /* POPUP FUNCTIONS */
        function showPopup(){
            document.getElementById("popup").classList.add("active");
        }

        // UX / UI Update 
        function closePopup(){
            document.getElementById("popup").classList.remove("active");
        }

    </script>

</body>
</html>
