<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport"
    content="width=device-width, initial-scale=1.0">

    <title>Smart Payment - Smart Canteen</title>

    <!-- FONT AWESOME -->
    <link rel="stylesheet"
    href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css"/>

    <style>

        *{
            margin:0;
            padding:0;
            box-sizing:border-box;
            font-family:Arial,sans-serif;
        }

        body{
            background:linear-gradient(to right,#111827,#1f2937);
            min-height:100vh;
        }

        /* HEADER */

        header{
            width:100%;
            padding:20px 8%;
            display:flex;
            justify-content:space-between;
            align-items:center;
            background:rgba(255,255,255,0.08);
            backdrop-filter:blur(10px);
        }

        .logo{
            color:white;
            font-size:32px;
            font-weight:bold;
        }

        .logo i{
            color:#f59e0b;
        }

        nav a{
            color:white;
            text-decoration:none;
            margin-left:25px;
            font-size:18px;
            transition:0.3s;
        }

        nav a:hover{
            color:#f59e0b;
        }

        /* PAYMENT SECTION */

        .payment-section{
            padding:60px 8%;
            display:flex;
            justify-content:center;
            align-items:center;
        }

        .payment-container{
            width:100%;
            max-width:1200px;
            display:grid;
            grid-template-columns:1fr 1fr;
            gap:40px;
        }

        /* LEFT SIDE */

        .left-side{
            color:white;
            display:flex;
            flex-direction:column;
            justify-content:center;
        }

        .left-side h1{
            font-size:65px;
            line-height:1.2;
            margin-bottom:25px;
        }

        .left-side p{
            font-size:20px;
            color:#d1d5db;
            line-height:1.9;
            margin-bottom:35px;
        }

        .payment-icons{
            display:flex;
            gap:25px;
            flex-wrap:wrap;
        }

        .payment-icons i{
            width:70px;
            height:70px;
            background:rgba(255,255,255,0.1);
            border-radius:15px;
            display:flex;
            justify-content:center;
            align-items:center;
            font-size:35px;
            transition:0.3s;
            cursor:pointer;
        }

        .payment-icons i:hover{
            background:#f59e0b;
            transform:translateY(-8px);
        }

        /* PAYMENT CARD */

        .payment-card{
            background:rgba(255,255,255,0.1);
            backdrop-filter:blur(15px);
            padding:40px;
            border-radius:25px;
            box-shadow:0 10px 30px rgba(0,0,0,0.3);
            color:white;
            position:relative;
            overflow:hidden;
        }

        .payment-card::before{
            content:'';
            width:180px;
            height:180px;
            background:#f59e0b;
            position:absolute;
            top:-60px;
            right:-60px;
            border-radius:50%;
            opacity:0.2;
        }

        .payment-card h2{
            font-size:38px;
            margin-bottom:30px;
        }

        .input-box{
            margin-bottom:22px;
        }

        .input-box label{
            display:block;
            margin-bottom:10px;
            font-size:17px;
        }

        .input-box input{
            width:100%;
            padding:16px 18px;
            border:none;
            border-radius:12px;
            background:rgba(255,255,255,0.15);
            color:white;
            font-size:17px;
            outline:none;
        }

        .input-box input::placeholder{
            color:#ddd;
        }

        .row{
            display:flex;
            gap:20px;
        }

        /* PAYMENT OPTION */

        .payment-option{
            margin:25px 0;
        }

        .payment-option h3{
            margin-bottom:15px;
            font-size:22px;
        }

        .option-box{
            display:flex;
            gap:20px;
            flex-wrap:wrap;
        }

        .option{
            flex:1;
            min-width:180px;
            padding:18px;
            border-radius:15px;
            background:rgba(255,255,255,0.12);
            cursor:pointer;
            transition:0.3s;
            border:2px solid transparent;
            text-align:center;
        }

        .option:hover{
            transform:translateY(-5px);
            border-color:#f59e0b;
        }

        .option.active{
            border-color:#22c55e;
            background:rgba(34,197,94,0.2);
        }

        .option i{
            font-size:35px;
            margin-bottom:10px;
            color:#f59e0b;
        }

        .option p{
            font-size:17px;
            font-weight:bold;
        }

        /* CARD DESIGN */

        .credit-card{
            width:100%;
            height:220px;
            background:linear-gradient(135deg,#f59e0b,#ff8800);
            border-radius:20px;
            padding:30px;
            margin-bottom:35px;
            position:relative;
            overflow:hidden;
        }

        .credit-card::before{
            content:'';
            width:120px;
            height:120px;
            background:rgba(255,255,255,0.2);
            position:absolute;
            top:-30px;
            right:-30px;
            border-radius:50%;
        }

        .chip{
            width:65px;
            height:50px;
            background:gold;
            border-radius:10px;
            margin-bottom:25px;
        }

        .card-number{
            font-size:28px;
            letter-spacing:3px;
            margin-bottom:25px;
        }

        .card-bottom{
            display:flex;
            justify-content:space-between;
            align-items:center;
        }

        .card-name{
            font-size:18px;
        }

        .visa{
            font-size:45px;
            font-weight:bold;
        }

        /* BUTTON */

        .pay-btn{
            width:100%;
            padding:18px;
            border:none;
            border-radius:12px;
            background:#22c55e;
            color:white;
            font-size:22px;
            cursor:pointer;
            transition:0.3s;
            margin-top:15px;
        }

        .pay-btn:hover{
            background:#16a34a;
            transform:scale(1.03);
        }

        /* POPUP */

        .popup{
            position:fixed;
            top:0;
            left:0;
            width:100%;
            height:100vh;
            background:rgba(0,0,0,0.7);
            display:flex;
            justify-content:center;
            align-items:center;
            visibility:hidden;
            opacity:0;
            transition:0.4s;
            z-index:9999;
        }

        .popup.show{
            visibility:visible;
            opacity:1;
        }

        .popup-box{
            width:400px;
            background:white;
            border-radius:25px;
            padding:40px 30px;
            text-align:center;
            transform:scale(0.5);
            transition:0.4s;
            box-shadow:0 20px 50px rgba(0,0,0,0.5);
        }

        .popup.show .popup-box{
            transform:scale(1);
        }

        .popup-icon{
            width:95px;
            height:95px;
            margin:auto;
            border-radius:50%;
            display:flex;
            justify-content:center;
            align-items:center;
            color:white;
            font-size:42px;
            margin-bottom:20px;
        }

        .success .popup-icon{
            background:#22c55e;
        }

        .error .popup-icon{
            background:#ef4444;
        }

        .popup-box h2{
            font-size:32px;
            color:#111827;
            margin-bottom:15px;
        }

        .popup-box p{
            font-size:18px;
            color:#555;
            line-height:1.7;
            margin-bottom:25px;
        }

        .popup-box button{
            padding:12px 35px;
            border:none;
            border-radius:10px;
            background:#f59e0b;
            color:white;
            font-size:17px;
            cursor:pointer;
            transition:0.3s;
        }

        .popup-box button:hover{
            background:#ff8800;
        }

        /* FOOTER */

        footer{
            text-align:center;
            color:white;
            padding:35px 8%;
            background:rgba(255,255,255,0.08);
            backdrop-filter:blur(10px);
            margin-top:40px;
        }

        footer h2{
            font-size:32px;
            margin-bottom:15px;
        }

        .social-icons{
            margin-top:20px;
        }

        .social-icons i{
            font-size:28px;
            margin:0 12px;
            cursor:pointer;
            transition:0.3s;
        }

        .social-icons i:hover{
            color:#f59e0b;
        }

        /* RESPONSIVE */

        @media(max-width:950px){

            .payment-container{
                grid-template-columns:1fr;
            }

            .left-side{
                text-align:center;
            }

            .payment-icons{
                justify-content:center;
            }
        }

        @media(max-width:768px){

            header{
                flex-direction:column;
                gap:15px;
            }

            .left-side h1{
                font-size:45px;
            }

            .row{
                flex-direction:column;
            }

            .card-number{
                font-size:20px;
            }

            .popup-box{
                width:90%;
            }

            .option-box{
                flex-direction:column;
            }
        }

    </style>

</head>
<body>

    <!-- HEADER -->

    <header>

        <div class="logo">

            <i class="fa-solid fa-credit-card"></i>
            Smart Canteen

        </div>

        <nav>

             <a href="../website/home.html">Home</a>
            <a href="../website/menu.html">Menu</a>
            <a href="../website/service.html">Services</a>
            <a href="../website/aboutus.html">About</a>
            <a href="../website/contactus.html">Contact</a>
            <a href="../website/cart.html">Cart</a>
            <a href="../website/billing.html">Bill</a>
            <a href="../website/payment.html">Payment</a>
            <a href="../website/login.html">Log in</a>

        </nav>

    </header>

    <!-- PAYMENT SECTION -->

    <section class="payment-section">

        <div class="payment-container">

            <!-- LEFT SIDE -->

            <div class="left-side">

                <h1>
                    Fast & Secure
                    Payment Gateway
                </h1>

                <p>
                    Complete your Smart Canteen order safely
                    with our modern digital payment system.
                    Enjoy secure transactions and quick checkout.
                </p>

                <div class="payment-icons">

                    <i class="fa-brands fa-google-pay"></i>

                    <i class="fa-brands fa-paypal"></i>

                    <i class="fa-brands fa-cc-visa"></i>

                    <i class="fa-brands fa-cc-mastercard"></i>

                </div>

            </div>

            <!-- PAYMENT CARD -->

            <div class="payment-card">

                <div class="credit-card">

                    <div class="chip"></div>

                    <div class="card-number">
                        4587 4587 4587 4587
                    </div>

                    <div class="card-bottom">

                        <div class="card-name">
                            SMART USER
                        </div>

                        <div class="visa">
                            VISA
                        </div>

                    </div>

                </div>

                <h2>Payment Details</h2>

                <!-- PAYMENT OPTIONS -->

                <div class="payment-option">

                    <h3>Select Payment Method</h3>

                    <div class="option-box">

                        <div class="option active"
                        onclick="selectMethod('card',this)">

                            <i class="fa-solid fa-credit-card"></i>

                            <p>Card Payment</p>

                        </div>

                        <div class="option"
                        onclick="selectMethod('cod',this)">

                            <i class="fa-solid fa-money-bill-wave"></i>

                            <p>Cash On Delivery</p>

                        </div>

                    </div>

                </div>

                <!-- CARD DETAILS -->

                <div id="cardDetails">

                    <div class="input-box">

                        <label>Card Holder Name</label>

                        <input type="text"
                        id="name"
                        placeholder="Enter Your Name">

                    </div>

                    <div class="input-box">

                        <label>Card Number</label>

                        <input type="text"
                        id="card"
                        placeholder="XXXX XXXX XXXX XXXX">

                    </div>

                    <div class="row">

                        <div class="input-box">

                            <label>Expiry Date</label>

                            <input type="text"
                            id="expiry"
                            placeholder="MM/YY">

                        </div>

                        <div class="input-box">

                            <label>CVV</label>

                            <input type="password"
                            id="cvv"
                            placeholder="123">

                        </div>

                    </div>

                </div>

                <button class="pay-btn"
                onclick="payNow()">

                    Pay ₹450

                </button>

            </div>

        </div>

    </section>

    <!-- POPUP -->

    <div class="popup" id="popup">

        <div class="popup-box">

            <div class="popup-icon">

                <i id="popupSymbol"
                class="fa-solid fa-circle-check"></i>

            </div>

            <h2 id="popupTitle">
                Success
            </h2>

            <p id="popupMessage">
                Payment Successful!
            </p>

            <button onclick="closePopup()">
                OK
            </button>

        </div>

    </div>

    <!-- FOOTER -->

    <footer>

        <h2>Smart Canteen Company</h2>

        <p>
            Smart Food Ordering Platform for Students & Companies.
        </p>

        <div class="social-icons">

            <i class="fa-brands fa-facebook"></i>

            <i class="fa-brands fa-instagram"></i>

            <i class="fa-brands fa-twitter"></i>

            <i class="fa-brands fa-linkedin"></i>

        </div>

        <p style="margin-top:20px;">
            © 2026 Smart Canteen. All Rights Reserved.
        </p>

    </footer>

    <!-- JAVASCRIPT -->

    <script>

        let paymentMethod = "card";

        function selectMethod(method,element){

            paymentMethod = method;

            let options =
            document.querySelectorAll(".option");

            options.forEach(option => {

                option.classList.remove("active");

            });

            element.classList.add("active");

            let cardDetails =
            document.getElementById("cardDetails");

            if(method === "cod"){

                cardDetails.style.display = "none";

            }
            else{

                cardDetails.style.display = "block";
            }
        }

        function showPopup(type,title,message){

            let popup =
            document.getElementById("popup");

            let popupTitle =
            document.getElementById("popupTitle");

            let popupMessage =
            document.getElementById("popupMessage");

            let popupSymbol =
            document.getElementById("popupSymbol");

            popup.className =
            "popup show " + type;

            popupTitle.innerText = title;

            popupMessage.innerText = message;

            if(type === "success"){

                popupSymbol.className =
                "fa-solid fa-circle-check";

            }
            else{

                popupSymbol.className =
                "fa-solid fa-circle-xmark";
            }
        }

        function closePopup(){

            document.getElementById("popup")
            .classList.remove("show");
        }

        function payNow(){

            if(paymentMethod === "cod"){

                showPopup(
                    "success",
                    "Order Confirmed!",
                    "Cash On Delivery selected successfully."
                );

                return;
            }

            let name =
            document.getElementById("name").value;

            let card =
            document.getElementById("card").value;

            let expiry =
            document.getElementById("expiry").value;

            let cvv =
            document.getElementById("cvv").value;

            if(name === "" ||
               card === "" ||
               expiry === "" ||
               cvv === ""){

                showPopup(
                    "error",
                    "Payment Failed!",
                    "Please fill all payment details correctly."
                );

            }
            else{

                showPopup(
                    "success",
                    "Payment Successful!",
                    "Your payment has been completed successfully."
                );
            }
        }

    </script>

</body>
</html>
